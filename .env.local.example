# Local dev — populated automatically by `npx convex dev` on first run.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Optional OAuth/email providers (see convex/auth.ts) — Password auth works
# without these; add them only once you configure Google/Microsoft/Resend.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_RESEND_KEY=

# Production only — a "Deploy Key" from the Convex dashboard (Settings ->
# Deploy Keys). Set this in Vercel's Project Settings -> Environment Variables
# (Production + Preview), NOT in this file. `npx convex deploy` uses it to
# push convex/ to the right deployment and to populate NEXT_PUBLIC_CONVEX_URL
# for the build — see vercel.json.
# CONVEX_DEPLOY_KEY=
